rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars - public read, own write
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Listing images - public read, auth write
    match /listings/{listingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Forum post images
    match /forum/{threadId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
